# ── Paladin System ────────────────────────────────────────────────────────────

# Mode: dummy (test generators) or production (real collectors)
PALADIN_MODE=dummy

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme123

# ── PostgreSQL (cold archive) ─────────────────────────────────────────────────
POSTGRES_DSN=postgresql://paladin:paladin@localhost:5432/paladin_archive

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# ── SearXNG ───────────────────────────────────────────────────────────────────
SEARXNG_URL=http://localhost:8080

# ── SAP Thresholds ────────────────────────────────────────────────────────────
SAP_SCORE_THRESHOLD=0.7
SAP_CORRELATION_WINDOW=60

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8888
DASHBOARD_SECRET=paladin-secret-change-me

# ── Archive Policy ────────────────────────────────────────────────────────────
ARCHIVE_LOG_DAYS=30
ARCHIVE_COMMS_DAYS=90
ARCHIVE_INCIDENT_DAYS=180

# ── Dummy Generators ─────────────────────────────────────────────────────────
DUMMY_EMPLOYEE_COUNT=15
DUMMY_EVENTS_PER_MIN=10
DUMMY_ANOMALY_PROB=0.05

# ── Protected Accounts ────────────────────────────────────────────────────────
PROTECTED_ACCOUNTS=admin,root,SYSTEM,paladin-service

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
